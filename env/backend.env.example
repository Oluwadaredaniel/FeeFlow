# ============================================================
# FeeFlow — Backend (apps/backend/.env)
# Copy this file to apps/backend/.env and fill in values.
# NEVER commit the real .env — it is gitignored.
# ============================================================

# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Direct Postgres connection (use the pooled/PgBouncer connection string for serverless)
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres?sslmode=require

# ---- Auth ----
JWT_SECRET=generate-a-long-random-string

# ---- Nomba (TEST creds for build week — see CLAUDE.md) ----
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_PARENT_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
# HMAC secret Nomba uses to sign webhooks (submit your webhook URL via the Nomba form)
NOMBA_WEBHOOK_SECRET=

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@feeflow.io

# ---- SMS (Twilio, optional) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
